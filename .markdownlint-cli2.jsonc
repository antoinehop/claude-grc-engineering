{
  // Config for markdownlint-cli2.
  // The toolkit's docs include long single-line tables, framework control
  // identifiers that look like emphasis (e.g. AC-2(1)), and verbatim quoted
  // regulation text. Relax the noisiest rules while keeping structural ones.
  "config": {
    "default": true,
    "line-length": false,
    "no-duplicate-heading": false,
    "no-inline-html": {
      "allowed_elements": ["b", "br", "details", "summary", "a", "img", "sub", "sup", "kbd", "table", "thead", "tbody", "tr", "th", "td", "control-id", "provider"]
    },
    "no-trailing-punctuation": { "punctuation": ".,;:!" },
    "no-bare-urls": false,
    "code-block-style": false,
    "first-line-heading": false,
    "heading-style": { "style": "atx" },
    "ul-style": { "style": "dash" },
    "fenced-code-language": false,
    "emphasis-style": false,
    "strong-style": false,
    "no-emphasis-as-heading": false,
    "ol-prefix": false
  },
  "ignores": [
    "node_modules/**",
    "**/generated/**"
  ]
}
